# ─── Telegram ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/foxguard
MONGODB_DB_NAME=foxguard

# ─── DeepSeek (LLM) ──────────────────────────────────────────────────────────
# Get from: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=

# ─── Pinecone (Vector DB) ────────────────────────────────────────────────────
# Get from: https://app.pinecone.io → API Keys
PINECONE_API_KEY=
PINECONE_INDEX_NAME=foxguard-knowledge

# ─── X / Twitter via RapidAPI ────────────────────────────────────────────────
# Get from: https://rapidapi.com → search "Twitter241" → Subscribe (free tier)
RAPIDAPI_KEY=
RAPIDAPI_HOST=twitter241.p.rapidapi.com

# ─── Services ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
